{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "latexDocumentName",
      "type": "promptString",
      "description": "Enter the new document directory name"
    }
  ],
  "tasks": [
    {
      "label": "Create new document",
      "type": "shell",
      "command": "make new NAME='${input:latexDocumentName}'"
    },
    {
      "label": "Build current document",
      "type": "shell",
      "command": "make build FILE='${file}'"
    },
    {
      "label": "Watch current document",
      "type": "shell",
      "command": "make watch FILE='${file}'"
    },
    {
      "label": "Lint current document",
      "type": "shell",
      "command": "make lint FILE='${file}'"
    },
    {
      "label": "Format current document",
      "type": "shell",
      "command": "make format FILE='${file}'"
    },
    {
      "label": "Clean current document",
      "type": "shell",
      "command": "make clean FILE='${file}'"
    },
    {
      "label": "Run doctor",
      "type": "shell",
      "command": "make doctor"
    }
  ]
}
